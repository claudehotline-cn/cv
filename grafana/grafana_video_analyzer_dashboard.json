{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
    ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "1" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "1" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "iteration": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Pipeline FPS",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "fps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "va_pipeline_fps{source_id=~\"$source\", path=~\"$path\"}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Processed FPS (rate)",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "fps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (source_id,path) (rate(va_frames_processed_total{source_id=~\"$source\", path=~\"$path\"}[1m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dropped FPS by reason",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "fps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\"}[1m]))" }
      ]
    },
    {
      "type": "stat",
      "title": "Drop Ratio (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "expr": "100 * (sum by (source_id,path) (rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\"}[5m])) / sum by (source_id,path) (rate(va_frames_processed_total{source_id=~\"$source\", path=~\"$path\"}[5m])))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency P95 by stage (ms)",
      "gridPos": { "h": 10, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le,stage) (rate(va_frame_latency_ms_bucket{source_id=~\"$source\", path=~\"$path\"}[5m])))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Encoder Bitrate (bps)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "8 * sum by (codec) (rate(va_encoder_bytes_total{source_id=~\"$source\", path=~\"$path\", codec=~\"$codec\"}[1m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Encoder EAGAIN rate",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (codec) (rate(va_encoder_eagain_total{source_id=~\"$source\", path=~\"$path\", codec=~\"$codec\"}[5m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backpressure & Queue Overflow (rate)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\", reason=\"backpressure\"}[5m]))" },
        { "refId": "B", "expr": "sum(rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\", reason=\"queue_overflow\"}[5m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RTSP Reconnects (rate)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "rate(va_rtsp_source_reconnects_total{source_id=~\"$source\"}[10m])" }
      ]
    },
    {
      "type": "timeseries",
      "title": "NVDEC Recover & Await-IDR (rate)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "rate(va_nvdec_device_recover_total{source_id=~\"$source\"}[10m])" },
        { "refId": "B", "expr": "rate(va_nvdec_await_idr_total{source_id=~\"$source\"}[10m])" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [ "video-analyzer", "observability" ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "label": "Datasource",
        "current": {}
      },
      {
        "type": "query",
        "name": "source",
        "label": "source_id",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(va_pipeline_fps, source_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 1
      },
      {
        "type": "query",
        "name": "path",
        "label": "path",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(va_pipeline_fps{source_id=~\"$source\"}, path)",
        "includeAll": true,
        "multi": true,
        "refresh": 1
      },
      {
        "type": "query",
        "name": "codec",
        "label": "codec",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(, encoder)",
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "browser",
  "title": "Video Analyzer Observability",
  "uid": "video-analyzer-obsv-01",
  "version": 1
}

