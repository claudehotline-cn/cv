{
  "schemaVersion": 38,
  "title": "Controlplane Overview",
  "timezone": "browser",
  "version": 1,
  "tags": [
    "cv",
    "controlplane"
  ],
  "panels": [
    {
      "type": "stat",
      "title": "SSE Connections (current)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "cp_sse_connections",
          "legendFormat": "connections"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "SSE Reconnects (5m)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "increase(cp_sse_reconnects[5m])",
          "legendFormat": "reconnects"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "graph",
      "title": "Requests by route/method/code (rps)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "lines": true,
      "targets": [
        {
          "expr": "sum by (route,method,code) (rate(cp_request_total[1m]))",
          "legendFormat": "{{route}} {{method}} {{code}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx ratio (5m)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(increase(cp_request_total{code=~\"5..\"}[5m])))/(sum(increase(cp_request_total[5m]))+1e-9)",
          "legendFormat": "5xx_ratio"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Top routes (5m)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (route,method,code) (increase(cp_request_total[5m])))",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "graph",
      "title": "Request duration (P50/P95/P99)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "lines": true,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le,route,method) (rate(cp_request_duration_ms_bucket[5m])))",
          "legendFormat": "p50 {{route}} {{method}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le,route,method) (rate(cp_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95 {{route}} {{method}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le,route,method) (rate(cp_request_duration_ms_bucket[5m])))",
          "legendFormat": "p99 {{route}} {{method}}"
        }
      ],
      "yaxes": [
        {
          "format": "ms"
        },
        {
          "format": "ms"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Backend errors (5m, by service/code)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "lines": true,
      "stack": true,
      "targets": [
        {
          "expr": "sum by (service,code) (increase(cp_backend_errors_total[5m]))",
          "legendFormat": "{{service}} {{code}}"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  }
}