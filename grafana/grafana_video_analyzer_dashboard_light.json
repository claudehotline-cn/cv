{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "1" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "1" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 0,
  "panels": [
    { "type": "row", "title": "Essentials", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "stat",
      "title": "Drop Ratio (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "expr": "100 * (sum by (source_id,path) (rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\"}[5m])) / sum by (source_id,path) (rate(va_frames_processed_total{source_id=~\"$source\", path=~\"$path\"}[5m])))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline FPS",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "fps" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "va_pipeline_fps{source_id=~\"$source\", path=~\"$path\"}" } ]
    },
    {
      "type": "timeseries",
      "title": "Latency P95 (ms)",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(va_frame_latency_ms_bucket{source_id=~\"$source\", path=~\"$path\"}[5m])))" } ]
    },
    {
      "type": "timeseries",
      "title": "Bitrate (bps)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "8 * sum by (source_id,path) (rate(va_encoder_bytes_total{source_id=~\"$source\", path=~\"$path\"}[1m]))" } ]
    },
    {
      "type": "timeseries",
      "title": "Backpressure / Queue Overflow (rate)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\", reason=\"backpressure\"}[5m]))" },
        { "refId": "B", "expr": "sum(rate(va_frames_dropped_total{source_id=~\"$source\", path=~\"$path\", reason=\"queue_overflow\"}[5m]))" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [ "video-analyzer", "light" ],
  "templating": {
    "list": [
      { "type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "label": "Datasource" },
      { "type": "query", "name": "source", "label": "source_id", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(va_pipeline_fps, source_id)", "includeAll": true, "multi": true, "refresh": 1 },
      { "type": "query", "name": "path", "label": "path", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "query": "label_values(va_pipeline_fps{source_id=~\"$source\"}, path)", "includeAll": true, "multi": true, "refresh": 1 }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "browser",
  "title": "VA Essentials (Read-only)",
  "uid": "va-essentials-ro-01",
  "version": 1
}

