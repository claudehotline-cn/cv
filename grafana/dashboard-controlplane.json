{
  "title": "Controlplane Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SSE Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "expr": "cp_sse_connections", "legendFormat": "connections" } ]
    },
    {
      "id": 2,
      "type": "graph",
      "title": "SSE Reconnects (per 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [ { "expr": "sum(rate(cp_sse_reconnects[5m]))", "legendFormat": "reconnects/s" } ]
    },
    {
      "id": 3,
      "type": "graph",
      "title": "HTTP Requests by code (per 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum by (code) (rate(cp_request_total[5m]))", "legendFormat": "code={{code}}" }
      ]
    },
    {
      "id": 4,
      "type": "graph",
      "title": "p95 Request Duration (ms) by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (route,method,le) (rate(cp_request_duration_ms_bucket[5m])))", "legendFormat": "{{route}} {{method}}" }
      ]
    },
    {
      "id": 5,
      "type": "graph",
      "title": "Backend Errors (per 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum by (service,method,code) (rate(cp_backend_errors_total[5m]))", "legendFormat": "{{service}} {{method}} code={{code}}" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Feature Toggle: Controlplane",
      "gridPos": { "h": 4, "w": 6, "x": 24, "y": 4 },
      "targets": [ { "expr": "cp_feature_enabled{feature=\"controlplane\"}", "legendFormat": "enabled" } ]
    }
  ]
}
