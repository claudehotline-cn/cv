{
  "title": "Video Analyzer Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Subscriptions Queue",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "va_subscriptions_queue_length{}", "legendFormat": "queue"}]
    },
    {
      "type": "stat",
      "title": "In Progress",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "va_subscriptions_in_progress{}", "legendFormat": "in_progress"}]
    },
    {
      "type": "graph",
      "title": "Completed (ready/failed/cancelled) per 5m",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(va_subscriptions_completed_total{result=\"ready\"}[5m]))", "legendFormat": "ready"},
        {"expr": "sum(rate(va_subscriptions_completed_total{result=\"failed\"}[5m]))", "legendFormat": "failed"},
        {"expr": "sum(rate(va_subscriptions_completed_total{result=\"cancelled\"}[5m]))", "legendFormat": "cancelled"}
      ]
    },
    {
      "type": "graph",
      "title": "Subscription p95 duration (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(va_subscription_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "graph",
      "title": "Phase p95 (opening/loading/starting)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(va_subscription_phase_seconds_bucket{phase=\"opening_rtsp\"}[5m])) by (le))", "legendFormat": "opening"},
        {"expr": "histogram_quantile(0.95, sum(rate(va_subscription_phase_seconds_bucket{phase=\"loading_model\"}[5m])) by (le))", "legendFormat": "loading"},
        {"expr": "histogram_quantile(0.95, sum(rate(va_subscription_phase_seconds_bucket{phase=\"starting_pipeline\"}[5m])) by (le))", "legendFormat": "starting"}
      ]
    },
    {
      "type": "stat",
      "title": "WAL failed_restart",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12},
      "targets": [{"expr": "va_wal_failed_restart_total{}", "legendFormat": "failed_restart"}]
    },
    {
      "type": "stat",
      "title": "Preheat enabled / warmed",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 12},
      "targets": [
        {"expr": "va_model_preheat_enabled{}", "legendFormat": "enabled"},
        {"expr": "va_model_preheat_warmed_total{}", "legendFormat": "warmed"}
      ]
    },
    {
      "type": "graph",
      "title": "Preheat p95 duration (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(va_model_preheat_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}
      ]
    }
  ]
}

