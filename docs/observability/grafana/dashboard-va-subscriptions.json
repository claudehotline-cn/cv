{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" }
  ],
  "title": "VA Subscriptions",
  "timezone": "",
  "panels": [
    {
      "type": "stat",
      "title": "In-Flight Subscriptions",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [{ "expr": "va_subscriptions_inflight" }]
    },
    {
      "type": "stat",
      "title": "Failure Rate (5m)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [{ "expr": "sum(rate(va_subscriptions_total{status=\"failed\"}[5m])) / clamp_min(sum(rate(va_subscriptions_total[5m])), 1)" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "P95 Duration (s)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(va_subscription_duration_seconds_bucket[5m])))" }]
    },
    {
      "type": "timeseries",
      "title": "Subscriptions By Status (rate)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "targets": [{ "expr": "sum by (status) (rate(va_subscriptions_total[5m]))" }]
    },
    {
      "type": "timeseries",
      "title": "Duration Histogram (rate)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "targets": [{ "expr": "sum by (le) (rate(va_subscription_duration_seconds_bucket[5m]))" }]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 36,
  "version": 1
}

