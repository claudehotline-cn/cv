# Sample TensorRT plan model config.pbtxt (dynamic batching + instance groups)
name: "det_trt_plan"
platform: "tensorrt_plan"
max_batch_size: 8

input [
  { name: "images" data_type: TYPE_FP32 dims: [3, 640, 640] }
]
output [
  { name: "output0" data_type: TYPE_FP32 dims: [NMS, 84] }
]

dynamic_batching {
  preferred_batch_size: [1, 4, 8]
  max_queue_delay_microseconds: 2000
}

instance_group [
  { kind: KIND_GPU count: 1 gpus: [0] }
]

optimization {
  # generic knobs here if needed; TensorRT-specific runtime is controlled by backend-config
}

parameters: {
  key: "infer_on_gpu"
  value: { string_value: "true" }
}

