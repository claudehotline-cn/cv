## Prebuilt ONNX Runtime (CUDA/TensorRT EP 可选)
## 固定版本：ORT_VERSION=1.23.2，CUDARCHS=120（如需修改，请直接编辑本文件）
## 构建命令：
##   docker build -f docker/va/Dockerfile.ort -t cv/va-ort:1.23.2-cuda13 .

FROM nvcr.io/nvidia/tensorrt:25.08-py3 AS build

ENV ORT_VERSION=1.23.2
ENV ORT_JOBS=24
ENV CUDARCHS=120
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential git ninja-build python3 python3-pip python3-dev ccache pkg-config \
    ca-certificates curl gnupg wget \
    && rm -rf /var/lib/apt/lists/*
RUN python3 -m pip install --upgrade pip wheel setuptools psutil packaging --break-system-packages || true

# 安装新版 CMake (>=3.28)
RUN set -eux; \
    wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /usr/share/keyrings/kitware-archive-keyring.gpg; \
    echo "deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ $(grep UBUNTU_CODENAME /etc/os-release | cut -d= -f2) main" > /etc/apt/sources.list.d/kitware.list; \
    apt-get update && apt-get install -y --no-install-recommends cmake && cmake --version

# TensorRT 头文件（若存在则启用 TRT EP）
RUN set -eux; \
    echo "deb https://developer.download.nvidia.com/compute/machine-learning/repos/ubuntu2204/x86_64 /" > /etc/apt/sources.list.d/nvidia-ml.list; \
    curl -fsSL https://developer.download.nvidia.com/compute/machine-learning/repos/ubuntu2204/x86_64/7fa2af80.pub | apt-key add - || true; \
    apt-get update && apt-get install -y --no-install-recommends \
      libnvinfer-dev libnvonnxparsers-dev libnvinfer-plugin-dev libnvinfer-bin || true

# 方便宿主编译器找到 CUDA 头
ENV CPLUS_INCLUDE_PATH=/usr/local/cuda/include:${CPLUS_INCLUDE_PATH}
ENV CPATH=/usr/local/cuda/include:${CPATH}

RUN mkdir -p /opt/onnxruntime/lib /opt/onnxruntime/include

# 构建 ONNX Runtime（CUDA + 可选 TensorRT）
RUN set -eux; \
    rm -rf /tmp/onnxruntime && git clone --depth 1 --branch v${ORT_VERSION} https://github.com/microsoft/onnxruntime.git /tmp/onnxruntime; \
    cd /tmp/onnxruntime; \
    CUDA_MAJ_MIN=$(nvcc --version | sed -n 's/.*release \([0-9]*\)\.\([0-9]*\).*/\1.\2/p' | head -n1); \
    TRT_FLAGS=""; \
    if [ -f /usr/include/NvInfer.h ] || [ -f /usr/include/x86_64-linux-gnu/NvInfer.h ]; then \
      TRT_FLAGS="--use_tensorrt --tensorrt_home=/usr"; \
    fi; \
    python3 tools/ci_build/build.py \
      --config Release \
      --build_dir /tmp/ort_build \
      --build_shared_lib \
      --skip_tests \
      --parallel ${ORT_JOBS} \
      --compile_no_warning_as_error \
      --cmake_generator Ninja \
      --cmake_path /usr/bin/cmake \
      --use_cuda --cuda_home=/usr/local/cuda --cudnn_home=/usr \
      --cuda_version=${CUDA_MAJ_MIN} \
      --cmake_extra_defines "CMAKE_CXX_FLAGS=-isystem /usr/local/cuda/include" \
      --cmake_extra_defines "CMAKE_CUDA_ARCHITECTURES=${CUDARCHS}" \
      --cmake_extra_defines "onnxruntime_USE_FLASH_ATTENTION=OFF" \
      --cmake_extra_defines "onnxruntime_DISABLE_CONTRIB_OPS=OFF" \
      --cmake_extra_defines "CMAKE_CXX_COMPILER_LAUNCHER=ccache" \
      --cmake_extra_defines "CMAKE_CUDA_COMPILER_LAUNCHER=ccache" \
      --cmake_extra_defines FETCHCONTENT_TRY_FIND_PACKAGE_MODE=NEVER \
      ${TRT_FLAGS} \
      --allow_running_as_root; \
    find /tmp/ort_build -type f -name 'libonnxruntime*.so*' -print | sort > /tmp/ort_libs.txt; \
    while IFS= read -r f; do cp -v "$f" /opt/onnxruntime/lib/; done < /tmp/ort_libs.txt; \
    cp -rv /tmp/onnxruntime/include/onnxruntime /opt/onnxruntime/include/ || true

RUN set -eux; \
    set +e; best=$(ls -1 /opt/onnxruntime/lib/libonnxruntime.so* 2>/dev/null | sort -V | tail -n1); set -e; \
    if [ -n "$best" ]; then \
      [ ! -e /opt/onnxruntime/lib/libonnxruntime.so ] && ln -s "$(basename "$best")" /opt/onnxruntime/lib/libonnxruntime.so; \
      [ ! -e /opt/onnxruntime/lib/libonnxruntime.so.1 ] && ln -s "$(basename "$best")" /opt/onnxruntime/lib/libonnxruntime.so.1; \
    fi; \
    echo "ort-${ORT_VERSION}-cuda$(nvcc --version | sed -n 's/.*release \([0-9]*\)\.\([0-9]*\).*/\1/p')-sm${CUDARCHS}" > /opt/onnxruntime/.build.tag; \
    ls -l /opt/onnxruntime/lib

FROM nvcr.io/nvidia/tensorrt:25.08-py3 AS runtime
COPY --from=build /opt/onnxruntime /opt/onnxruntime
ENV LD_LIBRARY_PATH=/opt/onnxruntime/lib:${LD_LIBRARY_PATH}

# 输出版本标记（可选）
RUN cat /opt/onnxruntime/.build.tag || true
