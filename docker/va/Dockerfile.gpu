# Video Analyzer (GPU) — requires NVIDIA Container Toolkit on host

# Parameterize CUDA/Ubuntu to match host if needed
ARG CUDA_VER=12.9.0
ARG UBUNTU_VER=22.04
FROM nvidia/cuda:${CUDA_VER}-cudnn-devel-ubuntu${UBUNTU_VER} AS build
# Re-declare build args inside the stage so they are available to RUN
ARG CUDA_VER
ARG UBUNTU_VER
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    build-essential cmake ninja-build git pkg-config curl ca-certificates \
    libssl-dev libyaml-cpp-dev libjsoncpp-dev \
    libopencv-dev \
    libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libswresample-dev \
    libgrpc++-dev protobuf-compiler protobuf-compiler-grpc libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

# Upgrade CMake to >=3.28 via Kitware APT (ORT 1.23.2 requires it)
RUN set -eux; \
    apt-get update && apt-get install -y wget gnupg && \
    wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /usr/share/keyrings/kitware-archive-keyring.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ jammy main" > /etc/apt/sources.list.d/kitware.list && \
    apt-get update && apt-get install -y --no-install-recommends cmake && \
    cmake --version

WORKDIR /app
COPY . /app

# Ensure destination for locally built ONNX Runtime exists early (defensive)
RUN mkdir -p /opt/onnxruntime/lib /opt/onnxruntime/include

# Build and install libdatachannel with OpenSSL backend to enable WHEP
RUN set -eux; \
    git clone --depth=1 --recursive https://github.com/paullouisageneau/libdatachannel.git /tmp/libdatachannel && \
    cmake -S /tmp/libdatachannel -B /tmp/libdatachannel/build -GNinja -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=ON -DUSE_OPENSSL=ON -DUSE_MBEDTLS=OFF -DUSE_GNUTLS=OFF && \
    cmake --build /tmp/libdatachannel/build -j && \
    cmake --install /tmp/libdatachannel/build && \
    rm -rf /tmp/libdatachannel

# Build and install IXWebSocket (library) for signaling WebSocket server (no TLS)
RUN set -eux; \
    git clone --depth=1 https://github.com/machinezone/IXWebSocket.git /tmp/ixwebsocket && \
    cmake -S /tmp/ixwebsocket -B /tmp/ixwebsocket/build -GNinja -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=ON -DUSE_TLS=OFF && \
    cmake --build /tmp/ixwebsocket/build -j && \
    cmake --install /tmp/ixwebsocket/build && \
    rm -rf /tmp/ixwebsocket

ARG ORT_VERSION=1.23.2
RUN set -eux; \
    # Python for ORT build tooling
    apt-get update && apt-get install -y python3 python3-pip python3-dev && \
    python3 -m pip install --upgrade pip wheel setuptools && \
    # Fetch ONNX Runtime source
    git clone --depth 1 --branch v${ORT_VERSION} https://github.com/microsoft/onnxruntime.git /tmp/onnxruntime && \
    cd /tmp/onnxruntime && \
    # Optional TensorRT EP if headers exist
    TRT_FLAGS=""; if [ -f /usr/include/NvInfer.h ]; then TRT_FLAGS="--use_tensorrt --tensorrt_home=/usr"; fi && \
    # Build ORT shared libs with CUDA EP, arch 90;120, 24 threads, Flash-Attention off
    python3 tools/ci_build/build.py \
      --config Release \
      --build_dir /tmp/ort_build \
      --build_shared_lib \
      --skip_tests \
      --parallel 24 \
      --cmake_generator Ninja \
      --use_cuda --cuda_home=/usr/local/cuda --cudnn_home=/usr \
      --cuda_version=${CUDA_VER%.*} \
      --cmake_extra_defines "CMAKE_CUDA_ARCHITECTURES=120" \
      --cmake_extra_defines "onnxruntime_USE_FLASH_ATTENTION=OFF" \
      --cmake_extra_defines FETCHCONTENT_TRY_FIND_PACKAGE_MODE=NEVER \
      --allow_running_as_root \
      ${TRT_FLAGS} && \
    # Install headers and libs to /opt/onnxruntime
    mkdir -p /opt/onnxruntime/lib /opt/onnxruntime/include && \
    cp -rv include/onnxruntime /opt/onnxruntime/include/ || true && \
    find /tmp/ort_build -type f -name 'libonnxruntime*.so*' -print | sort > /tmp/ort_libs.txt && \
    find /tmp/ort_build -type f -name 'libonnxruntime_providers_*' -print >> /tmp/ort_libs.txt && \
    test -s /tmp/ort_libs.txt || { echo "ERROR: ONNX Runtime libs not found"; find /tmp/ort_build -maxdepth 3 -type f | sed -n '1,200p'; exit 1; } && \
    while IFS= read -r f; do cp -v "$f" /opt/onnxruntime/lib/; done < /tmp/ort_libs.txt && \
    # Ensure SONAME symlinks exist for loader resolution
    set +e; best=$(ls -1 /opt/onnxruntime/lib/libonnxruntime.so* 2>/dev/null | sort -V | tail -n1); set -e; \
    if [ -n "$best" ]; then \
      if [ ! -e /opt/onnxruntime/lib/libonnxruntime.so ]; then ln -s "$(basename "$best")" /opt/onnxruntime/lib/libonnxruntime.so; fi; \
      if [ ! -e /opt/onnxruntime/lib/libonnxruntime.so.1 ]; then ln -s "$(basename "$best")" /opt/onnxruntime/lib/libonnxruntime.so.1; fi; \
    fi && \
    # Build VideoAnalyzer against locally built ONNX Runtime
    cd /app && \
    cmake -S video-analyzer -B build -G Ninja \
      -DUSE_CUDA=ON -DWITH_CUDA_KERNELS=ON -DWITH_NVDEC=ON -DWITH_NVENC=ON \
      -DUSE_GRPC=ON -DVA_ENABLE_GRPC_SERVER=ON \
      -DCMAKE_CUDA_ARCHITECTURES="120" \
      -DONNXRUNTIME_ROOT=/opt/onnxruntime \
      -DONNXRUNTIME_INCLUDE_DIR=/opt/onnxruntime/include/onnxruntime/core/session \
      -DONNXRUNTIME_LIB:FILEPATH=/opt/onnxruntime/lib/libonnxruntime.so \
    && cmake --build build -j

ARG CUDA_VER=12.9.0
ARG UBUNTU_VER=22.04
# Use cudnn-runtime to ensure libcudnn is available for ONNX Runtime CUDA EP
FROM nvidia/cuda:${CUDA_VER}-cudnn-runtime-ubuntu${UBUNTU_VER} AS runtime
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    ffmpeg libssl3 ca-certificates \
    libyaml-cpp0.7 libjsoncpp25 \
    libgrpc++1 \
    libopencv-core4.5 libopencv-imgproc4.5 \
    libopencv-videoio4.5 libopencv-highgui4.5 libopencv-imgcodecs4.5 libopencv-video4.5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /app/build/bin/VideoAnalyzer /app/bin/VideoAnalyzer
COPY --from=build /opt/onnxruntime /opt/onnxruntime
COPY --from=build /usr/local /usr/local
COPY video-analyzer/config /app/config
RUN mkdir -p /app/logs

ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
ENV VA_PROM_ENDPOINT=0.0.0.0:9090
ENV LD_LIBRARY_PATH=/opt/onnxruntime/lib:/usr/local/lib:${LD_LIBRARY_PATH}
EXPOSE 8082 9090 50051
ENTRYPOINT ["/app/bin/VideoAnalyzer","/app/config"]
