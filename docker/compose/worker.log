orders\\", \\"columns\\": [\\"id\\", \\"customer_id\\", \\"created_at\\", \\"amount\\", \\"status\\"], \\"foreign_keys\\": [\\"customer_id -> m_customers.id\\"]}, {\\"name\\": \\"models\\", \\"columns\\": [\\"id\\", \\"task\\", \\"family\\", \\"variant\\", \\"path\\", \\"conf\\", \\"iou\\", \\"created_at\\", \\"updated_at\\"], \\"foreign_keys\\": []}, {\\"name\\": \\"pipelines\\", \\"columns\\": [\\"name\\", \\"graph_id\\", \\"default_model_id\\", \\"encoder_cfg\\", \\"created_at\\", \\"updated_at\\"], \\"foreign_keys\\": []}, {\\"name\\": \\"sessions\\", \\"columns\\": [\\"id\\", \\"stream_id\\", \\"pipeline\\", \\"model_id\\", \\"status\\", \\"error_msg\\", \\"started_at\\", \\"stopped_at\\"], \\"foreign_keys\\": [\\"model_id -> models.id\\", \\"pipeline -> pipelines.name\\", \\"stream_id -> sources.id\\"]}, {\\"name\\": \\"sources\\", \\"columns\\": [\\"id\\", \\"uri\\", \\"status\\", \\"caps\\", \\"fps\\", \\"created_at\\", \\"updated_at\\"], \\"foreign_keys\\": []}, {\\"name\\": \\"train_jobs\\", \\"columns\\": [\\"id\\", \\"status\\", \\"phase\\", \\"cfg\\", \\"mlflow_run_id\\", \\"registered_model\\", \\"registered_version\\", \\"metrics\\", \\"art", "name": "llm_generate_sql", "langgraph_node": "llm_generate_sql", "subagent": null}'}
