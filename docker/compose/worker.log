agent-worker  | [AuditWorker Debug] Batch count: 10. First item type: <class 'dict'>. Content: {'event_id': '908aeb4c-b29e-4b49-8cfe-cb5e0e4f1463', 'schema_version': '1', 'event_type': 'tool_call_executed', 'event_time': '1769438948.6817667', 'run_id': '7fc6cd07-9f72-41b3-bc0c-a5e33b59ef4f', 'session_id': '03c82e2f-b1eb-4591-870c-b4940985df74', 'thread_id': '9d4b1fb6-a8ee-4150-9c6f-f788214375a4', 'span_id': '019bfac7-ad3d-7791-ba2c-16c64c8eb068', 'parent_span_id': '', 'component': 'tool', 'actor_type': 'agent', 'actor_id': 'worker', 'payload_json': '{"output_digest": "{\\"db_name\\": \\"cv_cp\\", \\"table\\": \\"m_orders\\", \\"columns\\": [\\"id\\", \\"customer_id\\", \\"created_at\\", \\"amount\\", \\"status\\"], \\"foreign_keys\\": [\\"customer_id -> m_customers.id\\"], \\"sample_rows\\": [{\\"id\\": 1, \\"customer_id\\": 1, \\"created_at\\": \\"2023-01-05 00:00:00\\", \\"amount\\": \\"150.00\\", \\"status\\": \\"paid\\"}, {\\"id\\": 2, \\"customer_id\\": 1, \\"created_at\\": \\"2023-01-15 00:00:00\\", \\"amount\\": \\"200.00\\", \\"status\\": \\"paid\\"}, {\\"id\\": 3, \\"customer_id\\": 1, \\"created_at\\": \\"2023-02-08 00:00:00\\", \\"amount\\": \\"180.00\\", \\"status\\": \\"paid\\"}, {\\"id\\": 4, \\"customer_id\\": 1, \\"created_at\\": \\"2023-02-20 00:00:00\\", \\"amount\\": \\"220.00\\", \\"status\\": \\"paid\\"}, {\\"id\\": 5, \\"customer_id\\": 1, \\"created_at\\": \\"2023-03-10 00:00:00\\", \\"amount\\": \\"300.00\\", \\"status\\": \\"paid\\"}]}", "tool_name": "data_db_table_schema"}'}
