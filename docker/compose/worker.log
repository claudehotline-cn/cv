\\\\\\\\\\\'total_amount\\\\\\\\\\\\\'].fillna(0)\\\\\\\\n\\\\\\\\n# 检查异常值（负值处理）\\\\\\\\nnegative_count = (df[\\\\\\\\\\\\\'total_amount\\\\\\\\\\\\\'] < 0).sum()\\\\\\\\nif negative_count > 0:\\\\\\\\n    df[\\\\\\\\\\\\\'total_amount\\\\\\\\\\\\\'] = df[\\\\\\\\\\\\\'total_amount\\\\\\\\\\\\\'].apply(lambda x: x if x >= 0 else 0)\\\\\\\\n\\\\\\\\n# 按月份排序\\\\\\\\ndf = df.sort_values(by=\\\\\\\\\\\\\'month\\\\\\\\\\\\\')\\\\\\\\n\\\\\\\\n# 转换为宽表格式（适合多系列折线图）\\\\\\\\npivot_df = df.pivot_table(\\\\\\\\n    index=\\\\\\\\\\\\\'month\\\\\\\\\\\\\',\\\\\\\\n    columns=\\\\\\\\\\\\\'city\\\\\\\\\\\\\',\\\\\\\\n    values=\\\\\\\\\\\\\'total_amount\\\\\\\\\\\\\',\\\\\\\\n    aggfunc=\\\\\\\\\\\\\'sum\\\\\\\\\\\\\',\\\\\\\\n    fill_value=0\\\\\\\\n)\\\\\\\\npivot_df = pivot_df.reset_index()\\\\\\\\n\\\\\\\\n# 验证结果\\\\\\\\nprint(\\"\\\\\\\\\\\\\\\\nData validation:\\")\\\\\\\\nprint(f\\"- Rows after processing: {len(pivot_df)}\\")\\\\\\\\nprint(f\\"- Columns in result: {pivot_df.columns.tolist()}\\")\\\\\\\\nprint(f\\"- Missing values check: {pivot_df.isna().any().any()}\\")\\\\\\\\nprint(f\\"- Negative values check: {(pivot_df.iloc[:,1:] < 0).any().any()}\\")\\\\\\\\n\\\\\\\\nresult = pivot_df\\\\\', \\\\\'python_result\\\\\': \\\\\'{\\"success\\":true,\\"stdout\\":\\"Columns: [\\\\\\\\\\\\\'city\\\\\\\\\\\\\', \\\\\\\\\\\\\'month\\\\\\\\\\\\\', \\\\\\\\\\\\\'total_amount\\\\\\\\\\\\\']\\\\\\\\\\\\\\\\nData types bef", "name": "tools", "langgraph_node": "tools", "subagent": null}'}
