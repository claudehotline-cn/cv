t sample:\\")\\\\nprint(result.head())\\\\nprint(\\"Result columns:\\", result.columns.tolist())\\\\nprint(\\"Result rows:\\", len(result))\'}", "name": "py_python_execute", "langgraph_node": "py_python_execute", "subagent": null}'}
