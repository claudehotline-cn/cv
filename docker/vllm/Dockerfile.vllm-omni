# 1. 依然使用 NVIDIA 官方 CUDA 13 底包 (为了支持 5090D)
FROM nvcr.io/nvidia/pytorch:25.12-py3

ENV DEBIAN_FRONTEND=noninteractive

# 2. 环境变量：解决 Ultra 285K 不支持 AVX-512 的问题
ENV TORCH_CUDA_ARCH_LIST="12.0"
ENV VLLM_TARGET_DEVICE="cuda"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    git \
    && rm -rf /var/lib/apt/lists/*

# 3. 卸载旧版本 (Image might have pre-installed libs)
RUN pip uninstall -y vllm vllm-omni

# 4. 关键：安装 vLLM 0.13.0 (CUDA 13.0 版)
# 从 GitHub Releases 直接安装 cu130 编译包，避免 PyPI 拉取 cu12 依赖
RUN pip install https://github.com/vllm-project/vllm/releases/download/v0.13.0/vllm-0.13.0+cu130-cp38-abi3-manylinux_2_35_x86_64.whl

# Install dependencies for Qwen3-Omni which might be missing
RUN pip install modelscope>=1.18.1 ffmpeg-python librosa soundfile

# 5. 用户指定版本覆盖 (User requested specific Transformers version for clean support)
RUN pip uninstall -y transformers && \
    pip install transformers==4.57.3 accelerate

# 5. 安装适配的 vllm-omni (Source)
# Cloning from source as it might track older version but we want to force usage with 0.13.0
WORKDIR /app
RUN git clone https://github.com/vllm-project/vllm-omni.git
# Use --no-deps to prevent it from downgrading vLLM to 0.12.x
RUN pip install ./vllm-omni --no-deps

# 6. 移除不兼容的 flash_attn (ABI 与 CUDA 13 不匹配导致 ImportError)
# vLLM 会自动回退到其他实现
# Cache bust: change this value to force rebuild from this step
ARG CACHEBUST=1
RUN pip uninstall -y flash_attn flash-attn || true

# Setup entrypoint
# We use the explicitly mounted entrypoint.py from docker-compose
CMD ["python3", "/app/entrypoint.py"]

ENV PYTHONPATH=/app:$PYTHONPATH
ENTRYPOINT ["python", "/app/entrypoint.py"]
