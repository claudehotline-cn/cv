# Dockerfile.vllm-omni
# Target: NVIDIA RTX 5090 (Blackwell sm_120) with Omni Capability
# Base Image: CUDA 13.1
FROM nvidia/cuda:13.1.0-devel-ubuntu22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV TORCH_CUDA_ARCH_LIST="12.0"
ENV VLLM_OMNI_REPO="https://github.com/vllm-project/vllm-omni.git"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3-pip \
    python3.10-dev \
    python3.10-venv \
    git \
    curl \
    ffmpeg \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y python3.12 python3.12-dev python3.12-venv \
    && rm -rf /var/lib/apt/lists/*

# Set up Python 3.12 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1

# Install pip for Python 3.12
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12

# Install setuptools first to provide distutils compatibility for Python 3.12
RUN pip install --no-cache-dir setuptools

# Install build dependencies
RUN pip install --no-cache-dir \
    packaging \
    ninja \
    setuptools \
    wheel \
    uv

# Working directory
WORKDIR /app

# Clone vLLM-Omni
RUN git clone ${VLLM_OMNI_REPO} vllm-omni
# Build PyTorch from source for CUDA 13.1 compatibility
# Clone PyTorch
RUN git clone --recursive --depth 1 https://github.com/pytorch/pytorch.git /tmp/pytorch
WORKDIR /tmp/pytorch

# Install PyTorch build dependencies
RUN pip install --no-cache-dir cmake typing_extensions pyyaml numpy

# Build PyTorch with Blackwell support
ENV MAX_JOBS=2
ENV USE_CUDA=1
ENV TORCH_CUDA_ARCH_LIST="12.0"

# Force reinstall setuptools to override system package (Python 3.12 needs this for distutils)
RUN pip install --force-reinstall --no-cache-dir setuptools

RUN python setup.py install

# Build torchvision
RUN git clone --depth 1 https://github.com/pytorch/vision.git /tmp/vision
WORKDIR /tmp/vision
RUN python setup.py install

# Build torchaudio  
RUN git clone --depth 1 https://github.com/pytorch/audio.git /tmp/audio
WORKDIR /tmp/audio
RUN python setup.py install

WORKDIR /app/vllm-omni

# Install vLLM-Omni from source
# This will take a while as it compiles kernels
RUN pip install -e .

# Expose port
EXPOSE 8000

# Install additional runtime deps (if any, e.g. for audio processing)
RUN apt-get update && apt-get install -y libsndfile1

# Entrypoint
# Support standard vLLM arguments
ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
