# 1. 依然使用 NVIDIA 官方 CUDA 13 底包 (为了支持 5090D)
FROM nvcr.io/nvidia/pytorch:25.12-py3

ENV DEBIAN_FRONTEND=noninteractive

# 2. 环境变量：解决 Ultra 285K 不支持 AVX-512 的问题
ENV TORCH_CUDA_ARCH_LIST="12.0"
ENV VLLM_TARGET_DEVICE="cuda"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    git \
    && rm -rf /var/lib/apt/lists/*

# 3. 卸载旧版本 (Image might have pre-installed libs)
RUN pip uninstall -y vllm vllm-omni

# 4. 关键：安装 vLLM 0.15.1 (CUDA 13.0 预编译 wheel)
# 注意：nvcr pytorch:25.12 自带 torch + CUDA 13.1；为避免 pip 解析 vLLM 依赖时拉取巨大的 torch/cu12 wheels，这里先 --no-deps
RUN pip install --no-deps https://github.com/vllm-project/vllm/releases/download/v0.15.1/vllm-0.15.1+cu130-cp38-abi3-manylinux_2_35_x86_64.whl

# 4.0 对齐 vLLM 0.15.1 的 torch ABI 版本，避免 vllm._C 符号不匹配
RUN pip uninstall -y torch torchvision torchaudio || true && \
    pip install --retries 20 --timeout 120 --prefer-binary \
    torch==2.9.1 torchvision==0.24.1 torchaudio==2.9.1

# 4.1 安装 vLLM 核心缺失依赖（拆分安装，降低网络抖动失败概率）
RUN pip install --retries 20 --timeout 120 --prefer-binary \
    cachetools cloudpickle compressed-tensors==0.13.0 depyf==0.20.0 \
    'llguidance>=1.3.0,<1.4.0' py-cpuinfo aiohttp==3.13.3 protobuf==6.33.5

# 4.2 安装 OpenAI server / 多模态相关依赖
RUN pip install --retries 20 --timeout 120 --prefer-binary \
    fastapi[standard]>=0.115.0 openai>=1.99.1 prometheus-fastapi-instrumentator>=7.0.0 \
    tiktoken>=0.6.0 sentencepiece ray>=2.48.0 opencv-python-headless>=4.13.0 numba==0.61.2 \
    flashinfer-python==0.6.1 lm-format-enforcer==0.11.3 xgrammar==0.1.29 outlines_core==0.2.11 \
    mistral_common>=1.8.8 gguf>=0.17.0 blake3 partial-json-parser msgspec diskcache==5.6.3 \
    lark==1.2.2 pybase64 cbor2 ijson setproctitle openai-harmony>=0.0.3 anthropic>=0.71.0 \
    model-hosting-container-standards>=0.1.13 mcp grpcio-reflection

# Install dependencies for Qwen3-Omni which might be missing
RUN pip install modelscope>=1.18.1 ffmpeg-python librosa soundfile omegaconf

# 5. 用户指定版本覆盖
RUN pip uninstall -y transformers accelerate && \
    pip install transformers==4.57.6 accelerate==1.12.0

# 6. 安装 vllm-omni (Source)
WORKDIR /app
RUN git clone --depth 1 --branch v0.15.0rc1 https://github.com/vllm-project/vllm-omni.git
# Use --no-deps to prevent it from downgrading vLLM.
RUN pip install ./vllm-omni --no-deps

# 7. 移除不兼容的 flash_attn (ABI 与 CUDA 13 不匹配导致 ImportError)
# vLLM 会自动回退到其他实现
# Cache bust: change this value to force rebuild from this step
ARG CACHEBUST=1
RUN pip uninstall -y flash_attn flash-attn || true

# Setup entrypoint
# We use the explicitly mounted entrypoint.py from docker-compose
CMD ["python3", "/app/entrypoint.py"]

ENV PYTHONPATH=/app:$PYTHONPATH
ENTRYPOINT ["python", "/app/entrypoint.py"]
